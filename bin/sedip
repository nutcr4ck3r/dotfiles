#!/bin/bash

# Get new IP from arg
NEW_IP="$1"

# Check arg
if [ -z "$NEW_IP" ]; then
  echo "Usage: $0 <new_IP>"
  exit 1
fi

# Replace IP address to new address on ~/.zshrc
sed -i "s/^export IP=[0-9.]\+/export IP=${NEW_IP}/" ~/git/dotfiles/files/.zshrc

echo "IP has renew to $NEW_IP"

